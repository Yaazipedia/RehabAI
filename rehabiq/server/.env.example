# RehabIQ Server — copy to .env and fill in values

# Required: Anthropic API key for AI features (get one at https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

PORT=3001

# Session cookie signing — use a long random string in production
SESSION_SECRET=change-this-to-a-long-random-string

# Single demo counselor login (no user database)
COUNSELOR_EMAIL=counselor@rehabiq.demo
COUNSELOR_PASSWORD=change-me-in-production

# Browser origin for CORS + cookies (Vite dev default)
CLIENT_ORIGIN=http://localhost:5173
